generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---

enum Role {
  ETUDIANT
  PROFESSEUR
}

enum TypeAnnonce {
  EXERCICE
  BON_PLAN
  TUTORAT
  PROJET
}

enum StatutCandidature {
  EN_ATTENTE
  ACCEPTEE
  REFUSEE
}

enum SousTypeBonPlan {
  JOB_ETUDIANT
  ALTERNANCE
  COLOCATION
  FETE
  EVENEMENT
  RESTAURANT
  BOURSE
  HACKATHON
}

enum CentreInteret {
  PROJET
  EXERCICE
  BON_PLAN
  ENTRAIDE
  MATIERE
}

enum Visibilite {
  PUBLIQUE
  PROMOTION
  PROFESSEUR
  ETUDIANT
  PROMO_SUPERIEUR
}

// --- HIÉRARCHIE ACADÉMIQUE ---

model Campus {
  id            BigInt        @id @default(autoincrement())
  nom           String
  ville         String
  etablissement String
  departements  Departement[]
}

model Departement {
  id         BigInt      @id @default(autoincrement())
  nom        String
  id_campus  BigInt
  campus     Campus      @relation(fields: [id_campus], references: [id])
  formations Formation[]
}

model Formation {
  id             BigInt        @id @default(autoincrement())
  nom            String
  niveau         String 
  id_departement BigInt
  departement    Departement   @relation(fields: [id_departement], references: [id])
  utilisateurs   Utilisateur[]
  matieres       Matiere[]     // Ajout de la relation inverse
}

// --- UTILISATEUR & SOCIAL ---

model Utilisateur {
  id               BigInt          @id @default(autoincrement())
  nom              String
  prenom           String
  email            String          @unique
  motDePasse       String
  role             Role
  dateInscription  DateTime        @default(now()) @db.Date
  photoProfil      String?
  centresInteret   CentreInteret[] // Tableau natif (PostgreSQL)
  bio              String?         @db.VarChar(500) // Limiter la taille est une bonne pratique

  id_formation     BigInt?
  formation        Formation?      @relation(fields: [id_formation], references: [id])
  
  // Relations d'autoblocage
  bloquants        Blocage[]       @relation("Bloquant")
  bloques          Blocage[]       @relation("Bloque")

  notifications    Notification[]
  commentaires     Commentaire[]
  jaimes           Jaime[]
  annoncesExercice AnnonceExercice[]
  annoncesBonPlan  AnnonceBonPlan[]
  annoncesTutorat  AnnonceTutorat[]
  annoncesProjet   AnnonceProjet[]
}

model Blocage {
  id_utilisateur_bloquant BigInt
  bloquant                Utilisateur @relation("Bloquant", fields: [id_utilisateur_bloquant], references: [id], onDelete: Cascade)
  id_utilisateur_bloque   BigInt
  bloque                  Utilisateur @relation("Bloque", fields: [id_utilisateur_bloque], references: [id], onDelete: Cascade)
  dateCreation            DateTime    @default(now())

  @@id([id_utilisateur_bloquant, id_utilisateur_bloque])
}

// --- ANNONCES (Modifiées avec Visibilité) ---

model AnnonceExercice {
  id              BigInt      @id @default(autoincrement())
  type            TypeAnnonce @default(EXERCICE)
  visibilite      Visibilite  @default(PUBLIQUE)
  datePublication DateTime    @default(now())
  nbJaime         Int         @default(0)
  image           String?
  lien            String?
  annee           String
  description     String
  id_utilisateur  BigInt
  utilisateur     Utilisateur @relation(fields: [id_utilisateur], references: [id], onDelete: Cascade)
  id_matiere      BigInt
  matiere         Matiere     @relation(fields: [id_matiere], references: [id], onDelete: Cascade)
  commentaires    Commentaire[]
  jaimes          Jaime[]
}

model AnnonceBonPlan {
  id              BigInt          @id @default(autoincrement())
  type            TypeAnnonce     @default(BON_PLAN)
  visibilite      Visibilite      @default(PUBLIQUE)
  datePublication DateTime        @default(now())
  nbJaime         Int             @default(0)
  image           String?
  lien            String?
  titre           String
  description     String
  sousType        SousTypeBonPlan
  id_utilisateur  BigInt
  utilisateur     Utilisateur     @relation(fields: [id_utilisateur], references: [id], onDelete: Cascade)
  commentaires    Commentaire[]
  jaimes          Jaime[]
}

model AnnonceTutorat {
  id                BigInt      @id @default(autoincrement())
  type              TypeAnnonce @default(TUTORAT)
  visibilite        Visibilite  @default(PUBLIQUE)
  datePublication   DateTime    @default(now())
  nbJaime           Int         @default(0)
  nbCandidatsVoulus Int
  description       String
  image             String?
  lien              String?
  annee             String
  id_utilisateur    BigInt
  utilisateur       Utilisateur @relation(fields: [id_utilisateur], references: [id], onDelete: Cascade)
  id_matiere        BigInt
  matiere           Matiere     @relation(fields: [id_matiere], references: [id], onDelete: Cascade)
  commentaires      Commentaire[]
  jaimes            Jaime[]
  candidatures      Candidature[]
}

model AnnonceProjet {
  id              BigInt      @id @default(autoincrement())
  type            TypeAnnonce @default(PROJET)
  visibilite      Visibilite  @default(PUBLIQUE)
  datePublication DateTime    @default(now())
  nbJaime           Int         @default(0)
  titre           String
  lien            String?
  image           String? 
  description     String
  id_utilisateur  BigInt
  utilisateur     Utilisateur @relation(fields: [id_utilisateur], references: [id], onDelete: Cascade)
  commentaires    Commentaire[]
  jaimes          Jaime[]
}

// --- AUTRES ---

model Matiere {
  id               BigInt            @id @default(autoincrement())
  titre            String
  formations       Formation[]       // Liste des formations qui ont cette matière
  
  annoncesExercice AnnonceExercice[]
  annoncesTutorat  AnnonceTutorat[]
}

model Notification {
  id             BigInt      @id @default(autoincrement())
  contenu        String
  dateCreation   DateTime    @default(now())
  lue            Boolean     @default(false)
  id_utilisateur BigInt
  utilisateur    Utilisateur @relation(fields: [id_utilisateur], references: [id], onDelete: Cascade)
}

model Commentaire {
  id             BigInt           @id @default(autoincrement())
  texte          String
  dateCreation   DateTime         @default(now())
  id_utilisateur BigInt
  utilisateur    Utilisateur      @relation(fields: [id_utilisateur], references: [id], onDelete: Cascade)
  id_exercice    BigInt?
  exercice       AnnonceExercice? @relation(fields: [id_exercice], references: [id], onDelete: Cascade)
  id_bonplan     BigInt?
  bonplan        AnnonceBonPlan?  @relation(fields: [id_bonplan], references: [id], onDelete: Cascade)
  id_tutorat     BigInt?
  tutorat        AnnonceTutorat?  @relation(fields: [id_tutorat], references: [id], onDelete: Cascade)
  id_projet      BigInt?
  projet         AnnonceProjet?   @relation(fields: [id_projet], references: [id], onDelete: Cascade)
}

model Jaime {
  id             BigInt           @id @default(autoincrement())
  date           DateTime         @default(now()) @db.Date
  id_utilisateur BigInt
  utilisateur    Utilisateur      @relation(fields: [id_utilisateur], references: [id], onDelete: Cascade)
  id_exercice    BigInt?
  exercice       AnnonceExercice? @relation(fields: [id_exercice], references: [id], onDelete: Cascade)
  id_bonplan     BigInt?
  bonplan        AnnonceBonPlan?  @relation(fields: [id_bonplan], references: [id], onDelete: Cascade)
  id_tutorat     BigInt?
  tutorat        AnnonceTutorat?  @relation(fields: [id_tutorat], references: [id], onDelete: Cascade)
  id_projet      BigInt?
  projet         AnnonceProjet?   @relation(fields: [id_projet], references: [id], onDelete: Cascade)
}

model Candidature {
  id                BigInt            @id @default(autoincrement())
  statut            StatutCandidature @default(EN_ATTENTE)
  date              DateTime         @default(now()) @db.Date
  messageMotivation String
  id_tutorat        BigInt
  tutorat           AnnonceTutorat    @relation(fields: [id_tutorat], references: [id], onDelete: Cascade)
}


// Inscription en attente : on stocke TOUTES les infos du futur compte + le code,
// AVANT la création réelle de l'utilisateur. Clé = email (écrasé à chaque renvoi).
// Le compte n'est créé (table Utilisateur) qu'une fois le code validé.
model VerificationEmail {
  id         BigInt    @id @default(autoincrement())
  email      String    @unique
  code       String
  expiration DateTime
  nom        String
  prenom     String
  motDePasse String // déjà hashé (bcrypt)
  role       Role
  id_formation BigInt?
}