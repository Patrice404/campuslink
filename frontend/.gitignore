# ========================
# DÉPENDANCES & BUILD
# ========================
node_modules/
dist/
dist-ssr/
*.tsbuildinfo

# (Note : package-lock.json n'est PAS ignoré, c'est voulu pour ton pipeline CI/CD)

# ========================
# VARIABLES D'ENVIRONNEMENT
# ========================
# On ignore les fichiers locaux qui contiennent des secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ATTENTION : On n'ignore PAS .env.production car GitHub Actions 
# en a besoin pour injecter l'URL d'Azure lors du build.

# ========================
# LOGS
# ========================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ========================
# SYSTÈME & ÉDITEURS (VS Code, Mac, etc.)
# ========================
.DS_Store
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?